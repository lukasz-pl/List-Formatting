{
  "elmType": "div",
  "style": {
    "width": "100%",
    "display": "=if([$Title] && [$AssignedTo.email], 'block', 'none')",
    "padding-top": "10px",
    "border-top": "1px solid"
  },
  "attributes": {
    "class": "ms-fontColor-neutralSecondary"
  },
  "children": [
    {
      "elmType": "a",
      "attributes": {
        "target": "_blank",
        "href": {
          "operator": "+",
          "operands": [
            "mailto:",
            "[$AssignedTo.email]",
            "?subject=Status zadania&body=Czesc, jak idzie Twoje zadanie (",
            "[$Title]",
            ")?"
          ]
        },
        "class": "ms-fontColor-themePrimary"
      },
      "children": [
        {
          "elmType": "span",
          "txtContent": "Wyślij e-mail do właściciela zadania"
        },
        {
          "elmType": "span",
          "style": {
            "margin-left": "8px",
            "vertical-align": "middle"
          },
          "attributes": {
            "iconName": "OutlookLogo",
            "class": "ms-fontColor-themePrimary ms-fontSize-xl"
          }
        }
      ]
    }
  ]
}
