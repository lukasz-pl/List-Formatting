{
  "elmType": "div",
  "style": {
    "width": "100%",
    "display": "=if([$Title], 'block', 'none')",
    "padding-top": "10px",
    "border-top": "1px solid"
  },
  "children": [
    {
      "elmType": "a",
      "attributes": {
        "target": "_blank",
        "href": {
          "operator": "+",
          "operands": [
            "https://teams.microsoft.com/l/meeting/new",
            "?subject=",
            "Spotkanie",
            "&attendees=",
            "joe@contoso.com",
            "&content=",
            "Czesc, zapraszam na spotkanie w sprawie (",
            "[$Title]",
            ")."
          ]
        },
        "class": "ms-fontColor-themePrimary"
      },
      "children": [
        {
          "elmType": "span",
          "txtContent": "Wyślij zaproszenie na spotkanie przez Microsoft Teams"
        },
        {
          "elmType": "span",
          "style": {
            "margin-left": "8px",
            "vertical-align": "middle"
          },
          "attributes": {
            "iconName": "TeamsLogo",
            "class": "ms-fontColor-themePrimary ms-fontSize-xl"
          }
        }
      ]
    }
  ]
}
