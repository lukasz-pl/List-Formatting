{
  "$schema": "https://developer.microsoft.com/json-schemas/sp/v2/view-formatting.schema.json",
  "hideSelection": true,
  "hideColumnHeader": true,
  "rowFormatter": {
    "elmType": "div",
    "style": {
      "display": "flex",
      "flex-wrap": "wrap",
      "width": "100%",
      "margin-bottom": "18px",
      "border": "1px solid #d8ccb8",
      "border-radius": "16px",
      "overflow": "hidden",
      "background": "linear-gradient(135deg, #fffdfa 0%, #f6efe4 100%)",
      "box-shadow": "0 10px 28px rgba(64, 43, 18, 0.08)"
    },
    "children": [
      {
        "elmType": "div",
        "style": {
          "width": "220px",
          "min-width": "220px",
          "padding": "18px",
          "background-color": "#efe2cf",
          "display": "flex",
          "flex-direction": "column",
          "justify-content": "space-between",
          "align-items": "center",
          "gap": "14px",
          "position": "relative"
        },
        "children": [
          {
            "elmType": "div",
            "style": {
              "position": "absolute",
              "top": "14px",
              "left": "14px",
              "display": "=if([$IsBestSeller] == true, 'block', 'none')",
              "padding": "6px 10px",
              "border-radius": "999px",
              "background-color": "#9f3a18",
              "color": "#ffffff",
              "font-size": "11px",
              "font-weight": "700",
              "letter-spacing": "0.8px",
              "text-transform": "uppercase"
            },
            "txtContent": "Bestseller"
          },
          {
            "elmType": "img",
            "attributes": {
              "src": "[$BookCoverUrl]",
              "alt": "[$Title]"
            },
            "style": {
              "width": "160px",
              "height": "230px",
              "margin-top": "18px",
              "object-fit": "cover",
              "border-radius": "10px",
              "border": "1px solid #cdbca0",
              "box-shadow": "0 10px 20px rgba(30, 20, 8, 0.18)"
            }
          },
          {
            "elmType": "div",
            "style": {
              "width": "100%",
              "padding": "12px",
              "border-radius": "12px",
              "background-color": "rgba(255,255,255,0.72)",
              "border": "1px solid #d8ccb8"
            },
            "children": [
              {
                "elmType": "div",
                "style": {
                  "font-size": "11px",
                  "font-weight": "700",
                  "letter-spacing": "1px",
                  "text-transform": "uppercase",
                  "color": "#7d6541",
                  "margin-bottom": "6px"
                },
                "txtContent": "Kategoria"
              },
              {
                "elmType": "div",
                "style": {
                  "font-size": "16px",
                  "font-weight": "700",
                  "color": "#2f2415"
                },
                "txtContent": "[$Category]"
              }
            ]
          }
        ]
      },
      {
        "elmType": "div",
        "style": {
          "flex-grow": "1",
          "min-width": "320px",
          "padding": "18px 20px 20px 20px",
          "display": "flex",
          "flex-direction": "column",
          "gap": "14px"
        },
        "children": [
          {
            "elmType": "div",
            "style": {
              "display": "flex",
              "justify-content": "space-between",
              "align-items": "flex-start",
              "gap": "16px",
              "flex-wrap": "wrap"
            },
            "children": [
              {
                "elmType": "div",
                "style": {
                  "display": "flex",
                  "flex-direction": "column",
                  "gap": "6px"
                },
                "children": [
                  {
                    "elmType": "div",
                    "style": {
                      "font-size": "11px",
                      "font-weight": "700",
                      "letter-spacing": "1px",
                      "text-transform": "uppercase",
                      "color": "#856944"
                    },
                    "txtContent": "Karta ksiazki"
                  },
                  {
                    "elmType": "div",
                    "style": {
                      "font-size": "30px",
                      "line-height": "1.1",
                      "font-weight": "700",
                      "color": "#2d2214"
                    },
                    "txtContent": "[$Title]"
                  },
                  {
                    "elmType": "div",
                    "style": {
                      "font-size": "15px",
                      "color": "#6d5433"
                    },
                    "txtContent": "= 'Autor: ' + [$BookAuthor]"
                  }
                ]
              },
              {
                "elmType": "div",
                "style": {
                  "display": "flex",
                  "gap": "10px",
                  "flex-wrap": "wrap",
                  "justify-content": "flex-end"
                },
                "children": [
                  {
                    "elmType": "div",
                    "style": {
                      "padding": "8px 12px",
                      "border-radius": "999px",
                      "background-color": "#fff7ea",
                      "border": "1px solid #e0cfae",
                      "font-size": "13px",
                      "font-weight": "700",
                      "color": "#8b4a12"
                    },
                    "txtContent": "= [$Price] + ' PLN'"
                  },
                  {
                    "elmType": "div",
                    "style": {
                      "padding": "8px 12px",
                      "border-radius": "999px",
                      "background-color": "=if([$IsBestSeller] == true, '#e8f3ff', '#f4efe8')",
                      "border": "=if([$IsBestSeller] == true, '1px solid #9fc3eb', '1px solid #d7cfc3')",
                      "font-size": "13px",
                      "font-weight": "700",
                      "color": "=if([$IsBestSeller] == true, '#0f548c', '#605448')"
                    },
                    "txtContent": "=if([$IsBestSeller] == true, 'Status: Bestseller', 'Status: Standard')"
                  }
                ]
              }
            ]
          },
          {
            "elmType": "div",
            "style": {
              "border": "1px solid #ded2c1",
              "border-radius": "14px",
              "overflow": "hidden",
              "background-color": "#fffdf9"
            },
            "children": [
              {
                "elmType": "div",
                "style": {
                  "display": "grid",
                  "grid-template-columns": "180px 1fr",
                  "background-color": "#f2e7d7",
                  "border-bottom": "1px solid #ded2c1"
                },
                "children": [
                  {
                    "elmType": "div",
                    "style": {
                      "padding": "12px 14px",
                      "font-size": "12px",
                      "font-weight": "700",
                      "text-transform": "uppercase",
                      "letter-spacing": "0.8px",
                      "color": "#6c5536"
                    },
                    "txtContent": "Pole"
                  },
                  {
                    "elmType": "div",
                    "style": {
                      "padding": "12px 14px",
                      "font-size": "12px",
                      "font-weight": "700",
                      "text-transform": "uppercase",
                      "letter-spacing": "0.8px",
                      "color": "#6c5536"
                    },
                    "txtContent": "Wartosc"
                  }
                ]
              },
              {
                "elmType": "div",
                "style": {
                  "display": "grid",
                  "grid-template-columns": "180px 1fr"
                },
                "children": [
                  {
                    "elmType": "div",
                    "style": {
                      "padding": "12px 14px",
                      "border-bottom": "1px solid #efe5d7",
                      "background-color": "#fbf7f0",
                      "font-size": "13px",
                      "font-weight": "700",
                      "color": "#5c472b"
                    },
                    "txtContent": "Tytul"
                  },
                  {
                    "elmType": "div",
                    "style": {
                      "padding": "12px 14px",
                      "border-bottom": "1px solid #efe5d7",
                      "font-size": "14px",
                      "color": "#2f2415"
                    },
                    "txtContent": "[$Title]"
                  },
                  {
                    "elmType": "div",
                    "style": {
                      "padding": "12px 14px",
                      "border-bottom": "1px solid #efe5d7",
                      "background-color": "#fbf7f0",
                      "font-size": "13px",
                      "font-weight": "700",
                      "color": "#5c472b"
                    },
                    "txtContent": "Autor"
                  },
                  {
                    "elmType": "div",
                    "style": {
                      "padding": "12px 14px",
                      "border-bottom": "1px solid #efe5d7",
                      "font-size": "14px",
                      "color": "#2f2415"
                    },
                    "txtContent": "[$BookAuthor]"
                  },
                  {
                    "elmType": "div",
                    "style": {
                      "padding": "12px 14px",
                      "border-bottom": "1px solid #efe5d7",
                      "background-color": "#fbf7f0",
                      "font-size": "13px",
                      "font-weight": "700",
                      "color": "#5c472b"
                    },
                    "txtContent": "Kategoria"
                  },
                  {
                    "elmType": "div",
                    "style": {
                      "padding": "12px 14px",
                      "border-bottom": "1px solid #efe5d7",
                      "font-size": "14px",
                      "color": "#2f2415"
                    },
                    "txtContent": "[$Category]"
                  },
                  {
                    "elmType": "div",
                    "style": {
                      "padding": "12px 14px",
                      "border-bottom": "1px solid #efe5d7",
                      "background-color": "#fbf7f0",
                      "font-size": "13px",
                      "font-weight": "700",
                      "color": "#5c472b"
                    },
                    "txtContent": "Cena"
                  },
                  {
                    "elmType": "div",
                    "style": {
                      "padding": "12px 14px",
                      "border-bottom": "1px solid #efe5d7",
                      "font-size": "14px",
                      "font-weight": "700",
                      "color": "#9f3a18"
                    },
                    "txtContent": "= [$Price] + ' PLN'"
                  },
                  {
                    "elmType": "div",
                    "style": {
                      "padding": "12px 14px",
                      "border-bottom": "1px solid #efe5d7",
                      "background-color": "#fbf7f0",
                      "font-size": "13px",
                      "font-weight": "700",
                      "color": "#5c472b"
                    },
                    "txtContent": "Data wydania"
                  },
                  {
                    "elmType": "div",
                    "style": {
                      "padding": "12px 14px",
                      "border-bottom": "1px solid #efe5d7",
                      "font-size": "14px",
                      "color": "#2f2415"
                    },
                    "txtContent": "[$ReleaseDate.displayValue]"
                  },
                  {
                    "elmType": "div",
                    "style": {
                      "padding": "12px 14px",
                      "background-color": "#fbf7f0",
                      "font-size": "13px",
                      "font-weight": "700",
                      "color": "#5c472b"
                    },
                    "txtContent": "Stan"
                  },
                  {
                    "elmType": "div",
                    "style": {
                      "padding": "12px 14px",
                      "font-size": "14px",
                      "color": "#2f2415"
                    },
                    "txtContent": "=if([$AddToCart] == true, 'W koszyku', 'Poza koszykiem')"
                  }
                ]
              }
            ]
          },
          {
            "elmType": "div",
            "style": {
              "padding": "14px 16px",
              "border-radius": "14px",
              "background-color": "#fffaf2",
              "border": "1px solid #e6d9c8"
            },
            "children": [
              {
                "elmType": "div",
                "style": {
                  "font-size": "11px",
                  "font-weight": "700",
                  "letter-spacing": "1px",
                  "text-transform": "uppercase",
                  "color": "#7d6541",
                  "margin-bottom": "8px"
                },
                "txtContent": "Opis ksiazki"
              },
              {
                "elmType": "div",
                "style": {
                  "font-size": "14px",
                  "line-height": "1.65",
                  "color": "#3a2d1d"
                },
                "txtContent": "[$BookAbstract]"
              }
            ]
          },
          {
            "elmType": "div",
            "style": {
              "display": "flex",
              "gap": "12px",
              "flex-wrap": "wrap"
            },
            "children": [
              {
                "elmType": "button",
                "customRowAction": {
                  "action": "setValue",
                  "actionInput": {
                    "AddToCart": "=if([$AddToCart] == true, false, true)"
                  }
                },
                "style": {
                  "padding": "10px 18px",
                  "border": "none",
                  "border-radius": "999px",
                  "background-color": "=if([$AddToCart] == true, '#5f6b5b', '#9f3a18')",
                  "color": "#ffffff",
                  "font-size": "14px",
                  "font-weight": "700",
                  "cursor": "pointer"
                },
                "txtContent": "=if([$AddToCart] == true, 'Usun z koszyka', 'Dodaj do koszyka')"
              },
              {
                "elmType": "a",
                "attributes": {
                  "href": "[$FindInStoreUrl]",
                  "target": "_blank"
                },
                "style": {
                  "padding": "10px 18px",
                  "border-radius": "999px",
                  "background-color": "#efe2cf",
                  "border": "1px solid #d3c0a4",
                  "color": "#3a2d1d",
                  "font-size": "14px",
                  "font-weight": "700",
                  "text-decoration": "none"
                },
                "txtContent": "Przejdz do sklepu"
              }
            ]
          }
        ]
      }
    ]
  }
}
